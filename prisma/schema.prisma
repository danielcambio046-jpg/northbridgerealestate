// NorthBridge Real Estate — Core Data Model

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum UserRole {
  INVESTOR
  SELLER
  AGENT
  DEVELOPER
  ADMIN
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
  DEVELOPMENT
  RENTAL
}

enum PropertyStatus {
  DRAFT
  PENDING_VERIFICATION
  ACTIVE
  UNDER_CONTRACT
  SOLD
}

enum LeadStatus {
  NEW
  QUALIFIED
  INTERESTED
  DUE_DILIGENCE
  NEGOTIATION
  CLOSED
  LOST
}

enum LeadSource {
  WEB
  WHATSAPP
  META_ADS
  GOOGLE_ADS
  REFERRAL
  DIRECT
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  name       String
  password   String?
  role       UserRole   @default(INVESTOR)
  kycStatus  KycStatus  @default(PENDING)
  properties Property[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Property {
  id          String          @id @default(cuid())
  ticker      String          @unique
  title       String
  description String?
  country     String
  state       String
  city        String
  type        PropertyType
  status      PropertyStatus  @default(PENDING_VERIFICATION)
  price       Decimal         @db.Decimal(15, 2)
  expectedRoi Decimal?        @db.Decimal(5, 2)
  capRate     Decimal?        @db.Decimal(5, 2)
  areaM2      Decimal?        @db.Decimal(10, 2)
  owner       User            @relation(fields: [ownerId], references: [id])
  ownerId     String
  media       PropertyMedia[]
  leads       Lead[]
  risk        RiskAssessment?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model PropertyMedia {
  id         String   @id @default(cuid())
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String
  url        String
  type       String   @default("IMAGE")
  order      Int      @default(0)
  createdAt  DateTime @default(now())
}

model Lead {
  id         String     @id @default(cuid())
  name       String
  email      String?
  phone      String?
  message    String?
  source     LeadSource @default(WEB)
  stage      LeadStatus @default(NEW)
  score      Int        @default(0)
  property   Property?  @relation(fields: [propertyId], references: [id])
  propertyId String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model RiskAssessment {
  id         String   @id @default(cuid())
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String   @unique
  riskScore  Int      @default(50)
  factors    Json?
  createdAt  DateTime @default(now())
}

