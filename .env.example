# Required to deploy.
DATABASE_URL="postgresql://user:password@host:5432/northbridge"

# Required now that auth exists. Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=""
# Required in production — set this to your deployed URL (e.g. the Vercel domain).
NEXTAUTH_URL="http://localhost:3000"

# Not required for this step. Needed for later phases:
ANTHROPIC_API_KEY=""
S3_BUCKET=""
AWS_REGION=""
WHATSAPP_BUSINESS_TOKEN=""
HUBSPOT_API_KEY=""
N8N_WEBHOOK_BASE_URL=""
